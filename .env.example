# ============================================================================
# CareConnect Backend Environment Variables
# ============================================================================
# COPY THIS FILE TO `.env` AND FILL IN YOUR ACTUAL VALUES
# NEVER COMMIT `.env` TO GIT!
# ============================================================================

# Django
SECRET_KEY=your_secret_key_here
DEBUG=False  # Set to False in production!
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# SQLite (dev only — leave unset to use default path)
# SQLITE_URL=sqlite:///db.sqlite3

# PostgreSQL
DB_NAME=cc_db
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Redis (required for Celery and Channels)
REDIS_URL=redis://127.0.0.1:6379/1
USE_REDIS=True

# Email (Brevo HTTP API - recommended)
# Sign up at https://brevo.com → SMTP & API → Generate API key
# Verify your sender email at Settings → Senders & IP (no domain needed)
USE_BREVO_API=True
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_SENDER_NAME=YourAppName
DEFAULT_FROM_EMAIL=YourAppName <your_sender_email@example.com>

# SMTP fallback (optional)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your_sender_email@example.com
EMAIL_HOST_PASSWORD=your_brevo_smtp_key_here

# CORS & Frontend URLs
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com
FRONTEND_BASE_URL=https://yourdomain.com
# Optional dev-only overrides for local frontend
FRONTEND_URL_LOCAL=http://localhost:3000
FRONTEND_BASE_URL_LOCAL=http://localhost:3000

# Jitsi Meet (Video Consultations)
JITSI_HOST=https://meet.jit.si
JITSI_DOMAIN=meet.jit.si

# ============================================================================
# PayMongo LIVE MODE (PRODUCTION)
# ============================================================================
# ⚠️ CRITICAL: REAL MONEY WILL BE CHARGED!
# 
# Get your live keys from: https://dashboard.paymongo.com
# 1. Log in to PayMongo Dashboard
# 2. Switch to "Live" mode (toggle in top-right)
# 3. Go to Developers → API Keys
# 4. Copy your Live Secret Key (starts with sk_live_...)
# 5. Copy your Live Public Key (starts with pk_live_...)
# 6. Go to Developers → Webhooks
# 7. Create webhook: https://yourdomain.com/pharmacy/paymongo/webhook/
# 8. Copy Webhook Signing Secret (starts with whsec_...)
# ============================================================================

# LIVE KEYS (replace with your actual keys from PayMongo dashboard)
PAYMONGO_SECRET_KEY=sk_live_YOUR_ACTUAL_LIVE_SECRET_KEY_HERE
PAYMONGO_PUBLIC_KEY=pk_live_YOUR_ACTUAL_LIVE_PUBLIC_KEY_HERE
PAYMONGO_WEBHOOK_SECRET=whsec_YOUR_ACTUAL_WEBHOOK_SECRET_HERE

# ============================================================================
# TEST MODE (for development/staging only)
# ============================================================================
# Uncomment these and comment out the live keys above to use test mode:
# PAYMONGO_SECRET_KEY=sk_test_YOUR_TEST_SECRET_KEY_HERE
# PAYMONGO_PUBLIC_KEY=pk_test_YOUR_TEST_PUBLIC_KEY_HERE
# PAYMONGO_WEBHOOK_SECRET=  # Not required for test mode
# ============================================================================

# ============================================================================
# Cloudinary (Media Storage)
# ============================================================================
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# AWS Rekognition Face Liveness
# ============================================================================
# Backend credentials create the liveness session and fetch results.
# AWS_LIVENESS_ROLE_ARN is the short-lived role assumed for the browser widget.
AWS_ACCESS_KEY_ID=your_backend_iam_access_key
AWS_SECRET_ACCESS_KEY=your_backend_iam_secret
AWS_REGION=us-east-1
AWS_LIVENESS_ROLE_ARN=arn:aws:iam::123456789012:role/LivenessFrontendRole
AWS_LIVENESS_SCORE_THRESHOLD=75

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# [ ] .env is in .gitignore (never commit to Git!)
# [ ] DEBUG=False in production
# [ ] ALLOWED_HOSTS contains your production domain
# [ ] SECRET_KEY is unique and secure (generate new one for production)
# [ ] Database password is strong and unique
# [ ] EMAIL_HOST_PASSWORD is a Brevo SMTP key (from Brevo dashboard → SMTP & API)
# [ ] PayMongo keys are LIVE keys (sk_live_... and pk_live_...)
# [ ] Webhook secret is configured
# [ ] HTTPS is enabled on your domain
# [ ] Redis is running and accessible
# ============================================================================
